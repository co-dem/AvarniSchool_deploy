{
  "builds": [
    {
      "src": "mysite/mysite/api/hello.py",
      "use": "@vercel/python",
      "config": { 
        "runtime": "python3.9"
      }
    },
    {
      "src": "mysite/mysite/wsgi.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "15mb", 
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/hello",
      "dest": "mysite/api/hello.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/mysite/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "mysite/mysite/wsgi.py"
    }
  ]
}
